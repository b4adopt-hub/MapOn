# ===== Supabase =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# service_role 키는 절대 프론트에 두지 않는다. Edge Function 시크릿으로만 보관.
SUPABASE_SERVICE_ROLE_KEY=

# ===== 공공 데이터 API (Edge Function 시크릿로 보관, 프론트 노출 금지) =====
# 브이월드: 지적도/용도지역/지목/경사/공시지가
VWORLD_KEY=
# 토지이음(공공데이터포털): 토지이용계획/규제/개발행위허가
LURIS_KEY=

# ===== 지도 표출 =====
# 카카오맵 JS 키 (2D 지도 + 경계 오버레이)
VITE_KAKAO_MAP_KEY=

# ===== 카카오 로그인 (OIDC, Supabase Auth 커스텀 provider) =====
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
